# ──────────────────────────────────────────────────────────────────
# Local Development
# ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://octa:octa_dev@localhost:5432/octa_dashboard
JWT_SECRET=change_me_in_production
INITIAL_ADMIN_EMAIL=admin@example.com
SKIP_LOGIN=true
AGENT_URLS=http://localhost:4001
RUST_LOG=info,dashboard_server=debug,knowledgebase_agent=debug

# GitHub OAuth (not needed if SKIP_LOGIN=true)
# GITHUB_CLIENT_ID=your_github_client_id
# GITHUB_CLIENT_SECRET=your_github_client_secret
# GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/github/callback

# Knowledgebase agent
# KB_STATIC_DIR=static
#
# The knowledgebase is a document-RAG agent. Document upload + indexing and the
# chat agent are optional — they activate only when these are set (otherwise the
# agent still runs, but those features are disabled). Set them here, or store
# them as Platform Secrets in the dashboard and the agent will fetch them.
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-5.4
# S3 (any S3-compatible store, e.g. AWS S3, DigitalOcean Spaces, MinIO)
# S3_REGION=nyc3
# S3_ACCESS_KEY=your_access_key
# S3_SECRET_KEY=your_secret_key
# S3_BUCKET=knowledgebase-docs
# S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
